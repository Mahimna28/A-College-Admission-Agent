# ============================================================
#  IBM Watsonx.ai  –  Credentials Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit the filled-in .env to version control.
# ============================================================

WATSONX_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Flask secret key (generate a random string for production)
FLASK_SECRET_KEY=change_me_to_a_random_secret_string

# Model ID — Llama 3.3 70B on IBM Watsonx.ai
MODEL_ID=meta-llama/llama-3-3-70b-instruct
